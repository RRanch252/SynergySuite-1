style=\"font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#a3956f;\">Conversation<\u002Fdiv>\n         <div class=\"cs\" style=\"font-size:18px;font-weight:700;color:#15293f;line-height:1.3;margin-top:4px;\">{{drawer.title}}<\u002Fdiv>\n       <\u002Fdiv>\n       <button type=\"button\" onclick=\"{{closeDrawer}}\" aria-label=\"Close\" style=\"flex:none;width:32px;height:32px;border-radius:8px;border:1px solid #e6e0d4;background:#fff;color:#6f7d8c;font-size:18px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#f7f4ee;\">×<\u002Fbutton>\n     <\u002Fdiv>\n     <div data-panel-body=\"\" style=\"flex:1;overflow-y:auto;padding:18px 20px;\">\n       <sc-if value=\"{{panelHasCtx}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"display:inline-flex;align-items:center;gap:7px;font-size:11.5px;font-weight:600;color:#2f6b4f;background:#eef5f0;border:1px solid #cfe1d6;border-radius:999px;padding:5px 12px;margin-bottom:14px;\"><span aria-hidden=\"true\" style=\"width:7px;height:7px;border-radius:50%;background:#2f6b4f;\"><\u002Fspan> {{panelCtxLabel}} conversation<\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-for list=\"{{convo}}\" as=\"d\" hint-placeholder-count=\"1\">\n       <div style=\"padding-top:{{d.turnPadTop}};margin-top:{{d.turnMarginTop}};border-top:{{d.turnBorder}};\">\n       <sc-if value=\"{{d.hasQ}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"display:flex;justify-content:flex-end;margin-bottom:15px;\">\n           <span style=\"font-size:14px;color:#15293f;background:#eef1f5;border-radius:14px 14px 4px 14px;padding:10px 14px;max-width:88%;line-height:1.45;\">{{d.q}}<\u002Fspan>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.illustrative}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"display:inline-flex;align-items:center;gap:6px;font-size:11.5px;font-weight:600;color:#bf8a2e;background:#faf2df;border:1px solid #ecdcb6;border-radius:6px;padding:6px 10px;margin-bottom:14px;\">Illustrative answer, depends on an integration<\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.rich}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"margin-bottom:20px;\">\n           <div class=\"cs\" style=\"font-size:21px;font-weight:700;color:#15293f;line-height:1.3;letter-spacing:-.01em;\">{{d.heroClaim}}<\u002Fdiv>\n           <div style=\"display:flex;align-items:baseline;gap:11px;margin-top:13px;flex-wrap:wrap;\">\n             <span class=\"cs\" style=\"font-size:44px;font-weight:700;color:#b23a2e;line-height:1;letter-spacing:-.02em;\">{{d.heroNum}}<\u002Fspan>\n             <span style=\"font-size:14px;color:#6f7d8c;line-height:1.45;max-width:240px;\">{{d.heroSub}}<\u002Fspan>\n           <\u002Fdiv>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.hasVerdict}}\" hint-placeholder-val=\"{{true}}\">\n         <div style=\"font-size:16.5px;font-weight:600;color:#15293f;line-height:1.5;margin-bottom:16px;\">{{d.verdict}}<\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.hasStats}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"display:flex;gap:9px;margin-bottom:15px;\">\n           <sc-for list=\"{{d.stats}}\" as=\"st\" hint-placeholder-count=\"3\">\n             <div style=\"flex:1;text-align:center;background:#f7f4ee;border-radius:9px;padding:11px 6px;\">\n               <div style=\"font-size:11px;color:#8a94a0;\">{{st.k}}<\u002Fdiv>\n               <div class=\"cs\" style=\"font-size:18px;font-weight:700;color:#15293f;margin-top:3px;\">{{st.v}}<\u002Fdiv>\n             <\u002Fdiv>\n           <\u002Fsc-for>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.hasChart}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"margin:2px 2px 12px;\">{{d.chartEl}}<\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.hasCaption}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"font-size:12px;color:#8a94a0;line-height:1.45