-height:1.5;\">{{dist.insight}}<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n\n        <!-- RIGHT: GP per ticket distribution -->\n        <div style=\"flex:1.25;min-width:320px;\">\n          <div style=\"display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;\">\n            <div style=\"font-size:11.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#a3956f;\">Spread of gross profit per {{dist.unit}}<\u002Fdiv>\n            <div role=\"group\" aria-label=\"Cut\" style=\"display:inline-flex;background:#f1ece1;border-radius:8px;padding:3px;\">\n              <sc-for list=\"{{gpCuts}}\" as=\"g\" hint-placeholder-count=\"2\">\n                <button type=\"button\" onclick=\"{{setGpCut}}\" data-cut=\"{{g.key}}\" aria-pressed=\"{{g.on}}\" style=\"border:none;cursor:pointer;font-family:inherit;font-size:12.5px;font-weight:600;padding:6px 12px;border-radius:6px;background:{{g.bg}};color:{{g.color}};\">{{g.label}}<\u002Fbutton>\n              <\u002Fsc-for>\n            <\u002Fdiv>\n          <\u002Fdiv>\n\n          <div style=\"display:flex;align-items:baseline;gap:14px;margin-top:10px;\">\n            <div><span class=\"cs\" style=\"font-size:26px;font-weight:700;color:#15293f;\">{{dist.mean}}<\u002Fspan> <span style=\"font-size:12px;color:#8a94a0;\">average<\u002Fspan><\u002Fdiv>\n            <div style=\"font-size:12.5px;color:#6f7d8c;\">target {{dist.target}} <span style=\"font-weight:600;color:#b6831f;\">{{dist.gap}}<\u002Fspan><\u002Fdiv>\n          <\u002Fdiv>\n\n          <svg viewBox=\"0 0 440 210\" width=\"100%\" style=\"display:block;margin-top:10px;overflow:visible;\" role=\"img\" aria-label=\"{{dist.alt}}\">\n            <line x1=\"24\" y1=\"170\" x2=\"424\" y2=\"170\" stroke=\"#e6e0d4\" stroke-width=\"1\"><\u002Fline>\n            <sc-for list=\"{{dist.bars}}\" as=\"b\" hint-placeholder-count=\"7\">\n              <rect x=\"{{b.x}}\" y=\"{{b.y}}\" width=\"{{b.w}}\" height=\"{{b.h}}\" rx=\"2.5\" fill=\"{{b.fill}}\"><\u002Frect>\n            <\u002Fsc-for>\n            <polyline points=\"{{dist.curve}}\" fill=\"none\" stroke=\"#2f6b4f\" stroke-width=\"2.4\" stroke-linejoin=\"round\" stroke-linecap=\"round\"><\u002Fpolyline>\n            <!-- target line -->\n            <line x1=\"{{dist.targetX}}\" y1=\"22\" x2=\"{{dist.targetX}}\" y2=\"170\" stroke=\"#bf8a2e\" stroke-width=\"1.5\" stroke-dasharray=\"5 4\"><\u002Fline>\n            <text x=\"{{dist.targetLabelX}}\" y=\"14\" text-anchor=\"start\" font-size=\"10\" font-weight=\"600\" fill=\"#bf8a2e\">target<\u002Ftext>\n            <!-- mean line -->\n            <line x1=\"{{dist.meanX}}\" y1=\"22\" x2=\"{{dist.meanX}}\" y2=\"170\" stroke=\"#15293f\" stroke-width=\"1.5\"><\u002Fline>\n            <text x=\"{{dist.meanLabelX}}\" y=\"14\" text-anchor=\"end\" font-size=\"10\" font-weight=\"600\" fill=\"#15293f\">avg<\u002Ftext>\n            <sc-for list=\"{{dist.axis}}\" as=\"a\" hint-placeholder-count=\"4\">\n              <text x=\"{{a.x}}\" y=\"188\" text-anchor=\"middle\" font-size=\"10.5\" fill=\"#8a94a0\">{{a.label}}<\u002Ftext>\n            <\u002Fsc-for>\n            <text x=\"224\" y=\"206\" text-anchor=\"middle\" font-size=\"10.5\" fill=\"#a3a9b1\">Gross profit per {{dist.unit}}<\u002Ftext>\n          <\u002Fsvg>\n\n          <div style=\"display:flex;flex-wrap:wrap;gap:9px 16px;margin-top:6px;\">\n            <span style=\"display:flex;align-items:center;gap:6px;font-size:11.5px;color:#6f7d8c;\"><span aria-hidden=\"true\" style=\"width:11px;height:11px;border-radius:3px;background:#cfe0d5;\"><\u002Fspan>Tickets in band<\u002Fspan>\n            <span style=\"display:flex;align-items:center;gap:6px;font-size:11.5px;color:#6f7d8c;\"><span aria-hidden=\"true\" style=\"width:11px;height:11px;border-radius:3px;background:#f1ddc2;\"><\u002Fspan>Below break even<\u002Fspan>\n            <span style=\"display:flex;align-items:center;gap:6px;font-size:11.5px;color:#6f7d8c;\"><span aria-hidden=\"true\" style=\"width:14px;height:0;border-top:2.4px solid #2f6b4f;\"><\u002Fspan>Distribution<\u002Fspan>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fsection>\n\n    <!-- ===== UPSELL PROMPTS ===== -->\n    <section aria-label=\"Upsell prompts\" hidden=\"{{s5Hidden}}\" style=\"order:{{ordUpsell}};grid-column:{{spanUpsell}};background:#fff;border:1px solid #e6e0d4;border-radius:9px;padding:20px 22px;\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;\">\n        <div class=\"cs\" style=\"font-size:18px;font-weight:700;color:#15293f;\">Upsell prompts<\u002Fdiv>\n        <span style=\"font-size:11px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#2f6b4f;background:#eaf1ed;border:1px solid #cfe1d6;border-radius:5px;padding:3px 8px;\">Live data<\u002Fspan>\n      <\u002Fdiv>\n      <div style=\"font-size:12.5px;color:#8a94a0;margin-top:2px;\">{{upsellSub}}<\u002Fdiv>\n      <div style=\"margin-top:14px;display:flex;flex-direction:column;gap:1px;\">\n        <sc-for list=\"{{upsell}}\" as=\"u\" hint-placeholder-count=\"4\">\n          <div style=\"display:flex;align-items:center;gap:12px;padding:11px 2px;border-bottom:1px solid #f3efe6;\">\n            <span aria-hidden=\"true\" style=\"flex:none;width:32px;height:32px;border-radius:8px;background:#eaf1ed;color:#2f6b4f;display:inline-flex;align-items:center;justify-content:center;\">{{plusIcon}}<\u002Fspan>\n            <div style=\"min-width:0;flex:1;\">\n              <div style=\"font-size:14px;font-weight:600;color:#15293f;\">{{u.name}}<\u002Fdiv>\n              <div style=\"font-size:12px;color:#8a94a0;\">{{u.note}}<\u002Fdiv>\n            <\u002Fdiv>\n            <div style=\"text-align:right;flex:none;\">\n              <div class=\"cs\" style=\"font-size:15px;font-weight:700;color:#2f6b4f;\">{{u.gp}}<\u002Fdiv>\n              <div style=\"font-size:10.5px;color:#a3a9b1;\">GP each<\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n      <div style=\"font-size:12px;color:#8a94a0;margin-top:14px;padding-top:12px;border-top:1px solid #efe9dd;\">Commissionable for floor staff. Attach target: a side on one in two tickets.<\u002Fdiv>\n    <\u002Fsection>\n\n    <!-- ===== PREDICTIVE VOLUMES ===== -->\n    <section aria-label=\"Predictive volumes\" hidden=\"{{s5Hidden}}\" style=\"order:{{ordVolumes}};grid-column:{{spanVolumes}};background:#fff;border:1px solid #e6e0d4;border-radius:9px;padding:20px 22px;\">\n      <div class=\"cs\" style=\"font-size:18px;font-weight:700;color:#15293f;\">Predictive volumes<\u002Fdiv>\n      <div style=\"font-size:12.5px;color:#8a94a0;margin-top:2px;\">{{volSubtitle}}<\u002Fdiv>\n      <div style=\"display:flex;flex-direction:column;gap:16px;margin-top:16px;\">\n        <sc-for list=\"{{volumes}}\" as=\"v\" hint-placeholder-count=\"3\">\n          <div>\n            <div style=\"display:flex;align-items:baseline;justify-content:space-between;gap:8px;\">\n              <span style=\"font-size:14px;font-weight:600;color:#15293f;\">{{v.name}}<\u002Fspan>\n              <span style=\"font-size:12.5px;font-weight:600;color:{{v.deltaColor}};\">{{v.delta}}<\u002Fspan>\n            <\u002Fdiv>\n            <div style=\"display:flex;align-items:center;gap:9px;margin-top:7px;\">\n              <span style=\"font-size:11px;color:#a3a9b1;width:34px;flex:none;\">This<\u002Fspan>\n              <div style=\"flex:1;height:12px;background:#f1ece1;border-radius:4px;overflow:hidden;\"><div style=\"height:100%;width:{{v.curPct}};background:#2f6b4f;border-radius:4px;\"><\u002Fdiv><\u002Fdiv>\n              <span style=\"font-size:12px;font-weight:600;color:#15293f;width:62px;flex:none;text-align:right;\">{{v.cur}}<\u002Fspan>\n            <\u002Fdiv>\n            <div style=\"display:flex;align-items:center;gap:9px;margin-top:5px;\">\n              <span style=\"font-size:11px;color:#a3a9b1;width:34px;flex:none;\">Last<\u002Fspan>\n              <div style=\"flex:1;height:12px;background:#f1ece1;border-radius:4px;overflow:hidden;\"><div style=\"height:100%;width:{{v.prevPct}};background:#cdc4b2;border-radius:4px;\"><\u002Fdiv><\u002Fdiv>\n              <span style=\"font-size:12px;color:#8a94a0;width:62px;flex:none;text-align:right;\">{{v.prev}}<\u002Fspan>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n      <div style=\"font-size:11.5px;color:#a3a9b1;margin-top:16px;padding-top:12px;border-top:1px solid #efe9dd;\">From the demand forecast, against the same period last year.<\u002Fdiv>\n    <\u002Fsection>\n\n    <!-- ===== MENU ENGINEERING ===== -->\n    <section aria-label=\"Menu engineering\" hidden=\"{{s5Hidden}}\" style=\"order:{{ordMenu}};grid-column:{{spanMenu}};background:#fff;border:1px solid #e6e0d4;border-radius:9px;padding:20px 22px;\">\n      <div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;\">\n        <div class=\"cs\" style=\"font-size:18px;font-weight:700;color:#15293f;\">Menu mix<\u002Fdiv>\n        <span style=\"font-size:11px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#2f6b4f;background:#eaf1ed;border:1px solid #cfe1d6;border-radius:5px;padding:3px 8px;\">Live data<\u002Fspan>\n      <\u002Fdiv>\n      <div style=\"font-size:12.5px;color:#8a94a0;margin-top:2px;\">{{menuSub}}<\u002Fdiv>\n\n      <div style=\"display:grid;grid-template-columns:1.35fr 1fr;gap:24px;margin-top:16px;align-items:start;\">\n        <div style=\"min-width:0;\">{{menuChartEl}}<\u002Fdiv>\n        <div style=\"min-width:0;\">\n          <div style=\"font-size:13px;color:#5a6675;line-height:1.5;\">{{menuNote}}<\u002Fdiv>\n          <div style=\"display:flex;flex-direction:column;gap:12px;margin-top:14px;\">\n            <sc-for list=\"{{menuCards}}\" as=\"c\" hint-placeholder-count=\"2\">\n              <div style=\"border-left:3px solid {{c.accent}};background:{{c.bg}};bor