  <button type=\"button\" onclick=\"{{onChip}}\" data-q=\"{{d.recActionQ}}\" style=\"margin-top:12px;border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13px;font-weight:600;padding:10px 15px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">{{d.recActionLabel}} →<\u002Fbutton>\n           <\u002Fsc-if>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n\n       <!-- de-boxed recommendation for rich answers: one move, the money, one action -->\n       <sc-if value=\"{{d.recRich}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"margin-top:20px;padding-top:18px;border-top:1px solid #ebe6da;\">\n           <div style=\"display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;\">\n             <span style=\"font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#a3a9b1;\">The move<\u002Fspan>\n             <sc-if value=\"{{d.hasRecMoney}}\" hint-placeholder-val=\"{{false}}\">\n               <span class=\"cs\" style=\"font-size:16px;font-weight:700;color:#2f6b4f;\">{{d.recMoney}}<\u002Fspan>\n             <\u002Fsc-if>\n           <\u002Fdiv>\n           <div style=\"font-size:15.5px;color:#15293f;line-height:1.5;margin-top:8px;\">{{d.recText}}<\u002Fdiv>\n           <sc-if value=\"{{d.hasRecAction}}\" hint-placeholder-val=\"{{false}}\">\n             <button type=\"button\" onclick=\"{{onChip}}\" data-q=\"{{d.recActionQ}}\" style=\"margin-top:14px;border:none;border-radius:9px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:12px 18px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">{{d.recActionLabel}} →<\u002Fbutton>\n           <\u002Fsc-if>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n       <sc-if value=\"{{d.canDownload}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"margin-top:16px;padding-top:15px;border-top:1px solid #f1ede4;\">\n           <div style=\"font-size:11px;font-weight:600;letter-sp