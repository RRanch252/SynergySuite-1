order}};border-radius:10px;padding:0 56px 0 44px;font-size:15px;color:#15293f;font-family:inherit;background:#fff;\" style-focus=\"border-color:#2f6b4f;box-shadow:0 0 0 3px rgba(47,107,79,.12);\">\n     <button type=\"button\" onclick=\"{{toggleVoice}}\" aria-pressed=\"{{voiceAria}}\" aria-label=\"{{voiceLabel}}\" style=\"position:absolute;right:8px;top:50%;transform:translateY(-50%);width:38px;height:38px;border-radius:9px;border:none;cursor:pointer;background:{{voiceBg}};color:{{voiceColor}};display:inline-flex;align-items:center;justify-content:center;font-family:inherit;\">\n       <sc-if value=\"{{voiceListening}}\" hint-placeholder-val=\"{{false}}\">\n         <span aria-hidden=\"true\" style=\"position:relative;display:inline-flex;align-items:center;justify-content:center;\">\n           <span style=\"position:absolute;width:34px;height:34px;border-radius:50%;background:#2f6b4f;opacity:.35;animation:soPulse 1.4s ease-out infinite;\"><\u002Fspan>\n           <span style=\"position:relative;display:inline-flex;\">{{micIconGreen}}<\u002Fspan>\n         <\u002Fspan>\n       <\u002Fsc-if>\n       <sc-if value=\"{{voiceIdleState}}\" hint-placeholder-val=\"{{true}}\">\n         <span aria-hidden=\"true\">{{micIconGrey}}<\u002Fspan>\n       <\u002Fsc-if>\n     <\u002Fbutton>\n     <sc-if value=\"{{showSuggest}}\" hint-placeholder-val=\"{{false}}\">\n       <div style=\"position:absolute;left:0;right:0;top:58px;z-index:40;background:#fff;border:1px solid #e6e0d4;border-radius:13px;box-shadow:0 18px 44px rgba(21,41,63,.16);padding:7px;overflow:hidden;\">\n         <div style=\"display:flex;align-items:center;justify-content:space-between;gap:10px;padding:7px 12px 8px;\">\n           <span style=\"font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#a3a9b1;\">{{suggestHeader}}<\u002Fspan>\n           <span style=\"font-size:10.5px;color:#c2b7a3;\">Enter to ask<\u002Fspan>\n         <\u002Fdiv>\n         <sc-for list=\"{{suggestRows}}\" as=\"sg\" hint-placeholder-count=\"4\">\n           <button type=\"button\" onmousedown=\"{{pickSuggest}}\" data-q=\"{{sg.q}}\" style=\"width:100%;text-align:left;background:none;border:none;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:11px;padding:11px 12px;border-radius:9px;\" style-hover=\"background:#f6f4ee;\">\n             <span aria-hidden=\"true\" style=\"flex:none;width:8px;height:8px;border-radius:50%;background:{{sg.dot}};\"><\u002Fspan>\n             <span style=\"flex:1;font-size:14.5px;color:#15293f;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;\">{{sg.label}}<\u002Fspan>\n             <span style=\"flex:none;font-size:10px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:{{sg.dot}};background:#faf8f3;border-radius:5px;padding:3px 7px;\">{{sg.cat}}<\u002Fspan>\n           <\u002Fbutton>\n         <\u002Fsc-for>\n         <div style=\"padding:8px 12px 5px;margin-top:3px;border-top:1px solid #f3efe6;font-size:11px;color:#a3a9b1;\">Every answer comes with a chart, the analysis and Finance, Ops, Sales, Procurement and QA views.<\u002Fdiv>\n       <\u002Fdiv>\n     <\u002Fsc-if>\n   <\u002Fform>\n   <div style=\"font-size:12px;color:#a3a9b1;margin-top:9px;\">Ask or speak a question. Answers are drawn live from your ops platform and name the agent that replied.<\u002Fdiv>\n\n   <!-- ORDER DAY: the decision -->\n   <sc-if value=\"{{doorOrder}}\" hint-placeholder-val=\"{{true}}\">\n     <div style=\"margin-top:24px;\">\n       <!-- TODAY layer: the operator's daily ritual, before you open and during the shift -->\n       <div style=\"border-left:3px solid #bf8a2e;padding:2px 0 2px 16px;margin-bottom:26px;\">\n         <div style=\"font-size:11px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#a3956f;\">Today, before you open<\u002Fdiv>\n\n         <!-- STORE, outstanding -->\n         <sc-if value=\"{{todayStoreOpen}}\" hint-placeholder-val=\"{{true}}\">\n           <div style=\"display:flex;align-items:baseline;gap:10px;margin-top:11px;flex-wrap:wrap;\">\n             <span class=\"cs\" style=\"font-size:24px;font-weight:700;color:#15293f;letter-spacing:-.01em;\">{{today.done}} of {{today.total}}<\u002Fspan>\n             <span style=\"font-size:14px;color:#6f7d8c;\">opening tasks done, {{today.out}} outstanding<\u002Fspan>\n           <\u002Fdiv>\n           <div style=\"margin-top:10px;max-width:560px;height:7px;background:#efe7d4;border-radius:4px;overflow:hidden;\">\n             <div style=\"height:100%;width:{{today.pct}};background:#bf8a2e;border-radius:4px;\"><\u002Fdiv>\n           <\u002Fdiv>\n\n           <div style=\"margin-top:18px;font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#a3a9b1;\">Your next task<\u002Fdiv>\n           <div style=\"display:flex;align-items:flex-start;gap:10px;margin-top:8px;\">\n             <sc-if value=\"{{today.nextRisk}}\" hint-placeholder-val=\"{{false}}\">\n               <span aria-hidden=\"true\" style=\"flex:none;margin-top:2px;color:#b23a2e;\">{{alertIconRed}}<\u002Fspan>\n             <\u002Fsc-if>\n             <div style=\"min-width:0;flex:1;\">\n               <div style=\"font-size:15.5px;font-weight:600;color:#15293f;line-height:1.4;\">{{today.nextTitle}}<\u002Fdiv>\n               <div style=\"font-size:14px;color:#6f7d8c;line-height:1.5;margin-top:4px;max-width:520px;\">{{today.nextDetail}}<\u002Fdiv>\n             <\u002Fdiv>\n           <\u002Fdiv>\n           <div style=\"display:flex;gap:12px;align-items:center;margin-top:13px;flex-wrap:wrap;\">\n             <button type=\"button\" onclick=\"{{openTasks}}\" style=\"border:none;border-radius:9px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 17px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Open task →<\u002Fbutton>\n             <button type=\"button\" onclick=\"{{signOffToday}}\" style=\"background:none;border:none;cursor:pointer;font-family:inherit;font-size:13px;font-weight:600;color:#6f7d8c;padding:4px 0;\" style-hover=\"color:#15293f;\">Sign off the rest →<\u002Fbutton>\n           <\u002Fdiv>\n\n           <sc-if value=\"{{today.breach}}\" hint-placeholder-val=\"{{false}}\">\n             <div style=\"margin-top:15px;border-left:3px solid #b23a2e;background:#fdf3f2;border-radius:0 8px 8px 0;padding:10px 14px;max-width:560px;\">\n               <div style=\"font-size:10.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#b23a2e;\">If you do nothing<\u002Fdiv>\n               <div style=\"font-size:13.5px;color:#3c4a5a;margin-top:4px;line-height:1.5;\">Opening tasks unsigned and a temperature breach unlogged is the gap a health audit closes a store over.<\u002Fdiv>\n             <\u002Fdiv>\n           <\u002Fsc-if>\n\n           <div style=\"display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:15px;flex-wrap:wrap;\">\n             <span style=\"font-size:12.5px;color:#9aa0a8;line-height:1.45;\">{{today.roleLine}}<\u002Fspan>\n             <button type=\"button\" onclick=\"{{openTasks}}\" style=\"flex:none;background:none;border:none;cursor:pointer;font-family:inherit;font-size:12.5px;font-weight:600;color:#6f7d8c;padding:4px 0;text-decoration:none;\" style-hover=\"text-decoration:underline;\">See all 50 tasks →<\u002Fbutton>\n           <\u002Fdiv>\n         <\u002Fsc-if>\n\n         <!-- STORE, all signed off -->\n         <sc-if value=\"{{todayStoreDone}}\" hint-placeholder-val=\"{{false}}\">\n           <div style=\"display:flex;align-items:center;gap:10px;margin-top:11px;\">\n             <span aria-hidden=\"true\" style=\"flex:none;display:inline-flex;color:#2f6b4f;\">{{checkIcon}}<\u002Fspan>\n             <span style=\"font-size:15.5px;font-weight:600;color:#2f6b4f;\">All opening tasks signed off, audit ready.<\u002Fspan>\n             <button type=\"button\" onclick=\"{{reopenToday}}\" style=\"background:none;border:none;cursor:pointer;font-family:inherit;font-size:12.5px;color:#9aa0a8;text-decoration:underline;padding:0;\">view<\u002Fbutton>\n           <\u002Fdiv>\n         <\u002Fsc-if>\n\n         <!-- REGIONAL / CORPORATE, aggregate -->\n         <sc-if value=\"{{today.multi}}\" hint-placeholder-val=\"{{false}}\">\n           <div style=\"display:flex;align-items:baseline;gap:10px;margin-top:11px;flex-wrap:wrap;\">\n             <span class=\"cs\" style=\"font-size:24px;font-weight:700;color:#15293f;letter-spacing:-.01em;\">{{today.aggSigned}} of {{today.aggTotal}}<\u002Fspan>\n             <span style=\"font-size:14px;color:#6f7d8c;\">outlets fully signed off this morning<\u002Fspan>\n           <\u002Fdiv>\n           <div style=\"display:flex;align-items:center;gap:10px;margin-top:12px;\">\n             <span aria-hidden=\"true\" style=\"flex:none;display:inline-flex;color:#b23a2e;\">{{alertIconRed}}<\u002Fspan>\n             <span style=\"font-size:14px;color:#3c4a5a;\">{{today.aggFlagged}} outlets flagged, opening checklist not yet complete.<\u002Fspan>\n           <\u002Fdiv>\n           <a href=\"https://niallfogarty.github.io/invrt-share/AI%20Agent%20Console%20(Standalone).html\" target=\"_blank\" rel=\"noopener\" style=\"display:inline-block;margin-top:13px;font-size:12.5px;font-weight:600;color:#6f7d8c;text-decoration:none;\" style-hover=\"text-decoration:underline;\">See the flagged outlets →<\u002Fa>\n         <\u002Fsc-if>\n       <\u002Fdiv>\n\n       <!-- the one urgent thing: a headline block, not a box. it wins by size and air. -->\n       <sc-if value=\"{{showEmergencyHeadline}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"margin:4px 0 30px;\">\n           <div style=\"display:flex;align-items:center;gap:8px;\">\n             <span aria-hidden=\"true\" style=\"display:inline-flex;color:#b23a2e;\">{{alertIconRed}}<\u002Fspan>\n             <span style=\"font-size:11.5px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:#b23a2e;\">Needs you now<\u002Fspan>\n           <\u002Fdiv>\n           <div class=\"cs\" style=\"font-size:25px;font-weight:700;color:#15293f;margin-top:12px;line-height:1.25;letter-spacing:-.01em;max-width:600px;\">Walk in fridge read 6°C at 7:40am, above range.<\u002Fdiv>\n           <div style=\"font-size:15px;color:#6f7d8c;margin-top:9px;line-height:1.5;max-width:560px;\">Check the beef received this morning before service. It is on your record from the probe reading either way.<\u002Fdiv>\n           <button type=\"button\" onclick=\"{{resolveSafety}}\" style=\"margin-top:15px;border:none;border-radius:9px;background:#b23a2e;color:#fff;font-size:14px;font-weight:600;padding:12px 18px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#9c2f24;\">Log the check →<\u002Fbutton>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n\n       <!-- reinforcement: a quiet line, no box -->\n       <sc-if value=\"{{hasWin}}\" hint-placeholder-val=\"{{false}}\">\n         <div style=\"display:flex;align-items:flex-start;gap:10px;margin:0 0 24px;\">\n           <span aria-hidden=\"true\" style=\"flex:none;margin-top:1px;color:#2f6b4f;\">{{checkIcon}}<\u002Fspan>\n           <div style=\"min-width:0;flex:1;\">\n             <span style=\"font-size:14px;color:#3c4a5a;line-height:1.5;\">{{winMsg}}<\u002Fspan>\n             <span style=\"font-size:12px;color:#a3a9b1;\"> · illustrative<\u002Fspan>\n           <\u002Fdiv>\n           <button type=\"button\" onclick=\"{{dismissWin}}\" aria-label=\"Dismiss\" style=\"flex:none;background:none;border:none;cursor:pointer;font-family:inherit;font-size:16px;color:#c2b7a3;line-height:1;padding:2px;\">×<\u002Fbutton>\n         <\u002Fdiv>\n       <\u002Fsc-if>\n\n       <div style=\"font-size:11px;font-weight:600;letter-spacing:.09em;text-transform:uppercase;color:#a3a9b1;\">This week, in priority order<\u002Fdiv>\n\n       <!-- board: a flat list. hairlines, not cards. -->\n       <div style=\"margin-top:8px;border-top:1px solid #ebe6da;\">\n         <sc-for list=\"{{activeCats}}\" as=\"c\" hint-placeholder-count=\"4\">\n           <div style=\"border-bottom:1px solid #ebe6da;\">\n             <button type=\"button\" onclick=\"{{toggleCat}}\" data-cat=\"{{c.id}}\" aria-expanded=\"{{c.open}}\" style=\"width:100%;text-align:left;background:none;border:none;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:16px;padding:18px 4px;\" style-hover=\"background:#faf8f3;\">\n               <span style=\"flex:1;min-width:0;\">\n                 <span style=\"display:block;font-size:15.5px;font-weight:600;color:#15293f;line-height:1.35;\">{{c.status}}<\u002Fspan>\n                 <span style=\"display:block;font-size:12.5px;color:#9aa0a8;margin-top:3px;\">{{c.name}}<\u002Fspan>\n               <\u002Fspan>\n               <span style=\"flex:none;font-size:12.5px;color:#9aa0a8;\">{{c.timeframe}}<\u002Fspan>\n               <span aria-hidden=\"true\" style=\"flex:none;display:inline-flex;color:#c8c2b4;font-size:11px;transform:{{c.chevRot}};transition:transform .18s;\">▾<\u002Fspan>\n             <\u002Fbutton>\n             <sc-if value=\"{{c.open}}\" hint-placeholder-val=\"{{false}}\">\n               <div style=\"padding:2px 4px 24px;\">\n\n                 <!-- food safety detail -->\n                 <sc-if value=\"{{c.isOpenSafety}}\" hint-placeholder-val=\"{{false}}\">\n                   <div style=\"margin-top:14px;border-left:3px solid #b23a2e;background:#fdf3f2;border-radius:0 9px 9px 0;padding:13px 16px;\">\n                     <div style=\"font-size:10.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#b23a2e;\">Temperature log · walk in<\u002Fdiv>\n                     <div style=\"font-size:14px;color:#3c4a5a;margin-top:6px;line-height:1.55;\">Check the beef received this morning before service. Logged from the probe reading, so it is on your record either way. Recorded at 7:40am, threshold 5°C.<\u002Fdiv>\n                     <button type=\"button\" onclick=\"{{resolveSafety}}\" style=\"margin-top:12px;border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 16px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Log the check →<\u002Fbutton>\n                   <\u002Fdiv>\n                 <\u002Fsc-if>\n\n                 <sc-for list=\"{{c.catLinks}}\" as=\"l\" hint-placeholder-count=\"1\">\n             <div style=\"padding-top:14px;min-width:0;\">\n               <div style=\"font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:#a3956f;\">{{l.name}}<\u002Fdiv>\n               <sc-if value=\"{{l.notBottom}}\" hint-placeholder-val=\"{{true}}\">\n               <div style=\"display:flex;align-items:flex-start;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-top:4px;\">\n                 <div style=\"flex:1;min-width:200px;\">\n                   <button type=\"button\" onclick=\"{{toggleFig}}\" data-fig=\"{{l.id}}\" aria-expanded=\"{{l.open}}\" style=\"background:none;border:none;cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:10px;padding:5px 0 0;margin:0;\">\n                     <span class=\"cs\" style=\"font-size:27px;font-weight:700;color:{{l.valColor}};border-bottom:{{l.valBorder}};padding-bottom:2px;line-height:1;\">{{l.value}}<\u002Fspan>\n                     <span aria-hidden=\"true\" style=\"display:inline-flex;color:#c2b7a3;font-size:11px;transform:{{l.chevronRot}};transition:transform .18s;\">▾<\u002Fspan>\n                   <\u002Fbutton>\n                   <div style=\"font-size:14.5px;color:#3c4a5a;margin-top:9px;line-height:1.5;max-width:420px;\">{{l.line}}<\u002Fdiv>\n                   <sc-if value=\"{{l.isFootfall}}\" hint-placeholder-val=\"{{false}}\">\n                     <div style=\"margin-top:14px;\">{{l.footfallChartEl}}<\u002Fdiv>\n                     <div style=\"font-size:13px;color:#6f7d8c;margin-top:11px;line-height:1.5;max-width:440px;\">This week runs above last week and last year all week. Dry weather adds about 6% across the weekend; the Saturday concert adds about 9% on the night.<\u002Fdiv>\n                     <div style=\"margin-top:12px;display:flex;flex-direction:column;gap:7px;max-width:440px;\">\n                       <div style=\"font-size:10.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#a3956f;\">Inputs to this forecast<\u002Fdiv>\n                       <div style=\"display:flex;align-items:center;gap:9px;background:#faf8f3;border:1px solid #eee9dd;border-radius:9px;padding:9px 12px;\">\n                         <span aria-hidden=\"true\" style=\"flex:none;color:#bf8a2e;display:inline-flex;\">{{sunIcon}}<\u002Fspan>\n                         <div style=\"min-width:0;flex:1;\">\n                           <span style=\"font-size:13px;color:#15293f;\">Weather: dry and warm, about 21°C, Friday to Sunday<\u002Fspan>\n                           <span style=\"font-size:12.5px;color:#2f6b4f;font-weight:600;\"> · lifts covers about 6%<\u002Fspan>\n                         <\u002Fdiv>\n                         <span style=\"flex:none;font-size:9.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#bf8a2e;border:1px solid #ecdcb8;border-radius:4px;padding:2px 6px;\">Illustrative<\u002Fspan>\n                       <\u002Fdiv>\n                       <div style=\"display:flex;align-items:center;gap:9px;background:#faf8f3;border:1px solid #eee9dd;border-radius:9px;padding:9px 12px;\">\n                         <span aria-hidden=\"true\" style=\"flex:none;color:#6f7d8c;display:inline-flex;\">{{calIcon}}<\u002Fspan>\n                         <div style=\"min-width:0;flex:1;\">\n                           <span style=\"font-size:13px;color:#15293f;\">Event: arena concert, Saturday 8pm<\u002Fspan>\n                           <span style=\"font-size:12.5px;color:#2f6b4f;font-weight:600;\"> · lifts covers about 9%<\u002Fspan>\n                         <\u002Fdiv>\n                         <span style=\"flex:none;font-size:9.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#2f6b4f;background:#eaf1ed;border:1px solid #cfe1d6;border-radius:4px;padding:2px 6px;\">Live<\u002Fspan>\n                       <\u002Fdiv>\n                     <\u002Fdiv>\n                   <\u002Fsc-if>\n                   <sc-if value=\"{{l.hasAddEvent}}\" hint-placeholder-val=\"{{false}}\">\n                     <sc-if value=\"{{eventAdded}}\" hint-placeholder-val=\"{{false}}\">\n                       <div style=\"display:inline-flex;align-items:center;gap:7px;margin-top:12px;font-size:12.5px;font-weight:600;color:#2f6b4f;\">{{checkIcon}} Added to your forecast<\u002Fdiv>\n                     <\u002Fsc-if>\n                     <sc-if value=\"{{eventAddedNot}}\" hint-placeholder-val=\"{{true}}\">\n                       <button type=\"button\" onclick=\"{{addLocalEvent}}\" style=\"display:inline-flex;align-items:center;gap:7px;margin-top:12px;background:#fff;border:1px solid #e0d8c9;border-radius:8px;cursor:pointer;font-family:inherit;font-size:12.5px;font-weight:600;color:#6f7d8c;padding:8px 13px;\" style-hover=\"background:#f7f4ee;border-color:#cdc4b2;\"><span aria-hidden=\"true\" style=\"display:inline-flex;\">{{plusIcon}}<\u002Fspan> Add a local event<\u002Fbutton>\n                       <div style=\"font-size:11.5px;color:#a3a9b1;margin-top:6px;line-height:1.45;max-width:380px;\">Something no public feed knows, like a match in the field next door. It sharpens the forecast.<\u002Fdiv>\n                     <\u002Fsc-if>\n                   <\u002Fsc-if>\n                 <\u002Fdiv>\n                 <sc-if value=\"{{l.notFootfall}}\" hint-placeholder-val=\"{{true}}\">\n                 <button type=\"button\" onclick=\"{{toggleFig}}\" data-fig=\"{{l.id}}\" aria-label=\"Chart, tap for source\" style=\"background:none;border:none;cursor:pointer;padding:6px 0 0;margin:0;flex:none;width:248px;max-width:100%;\">{{l.chartEl}}<\u002Fbutton>\n                 <\u002Fsc-if>\n               <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- bottom row: two labelled variants side by side (testing language) -->\n               <sc-if value=\"{{l.isBottom}}\" hint-placeholder-val=\"{{false}}\">\n                 <!-- primary framing: gross profit per ticket to target -->\n                 <div style=\"display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;margin-top:6px;\">\n                   <span class=\"cs\" style=\"font-size:30px;font-weight:700;color:#15293f;border-bottom:2px solid #bf8a2e;padding-bottom:2px;line-height:1;\">$13.40<\u002Fspan>\n                   <span style=\"font-size:13px;color:#6f7d8c;padding-bottom:2px;\">gross profit per ticket, against a $14.20 target<\u002Fspan>\n                 <\u002Fdiv>\n                 <div style=\"margin-top:14px;max-width:560px;\">\n                   <div style=\"position:relative;height:12px;background:#f1ece1;border-radius:6px;\">\n                     <div style=\"position:absolute;left:0;top:0;bottom:0;width:94.4%;background:#15293f;border-radius:6px;\"><\u002Fdiv>\n                     <div style=\"position:absolute;left:94.4%;top:-3px;bottom:-3px;width:2px;background:#bf8a2e;\"><\u002Fdiv>\n                   <\u002Fdiv>\n                   <div style=\"display:flex;justify-content:space-between;margin-top:6px;\">\n                     <span style=\"font-size:11.5px;color:#6f7d8c;\">Now $13.40<\u002Fspan>\n                     <span style=\"font-size:11.5px;font-weight:600;color:#bf8a2e;\">Target $14.20<\u002Fspan>\n                   <\u002Fdiv>\n                 <\u002Fdiv>\n                 <div style=\"font-size:14.5px;color:#3c4a5a;margin-top:14px;line-height:1.5;max-width:560px;\">{{l.line}}<\u002Fdiv>\n                 <!-- alternate framing: prime cost, the two dials the operator already turns -->\n                 <div style=\"margin-top:16px;padding-top:14px;border-top:1px solid #efe9dd;max-width:560px;\">\n                   <div style=\"font-size:10.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#a3956f;\">Same week, read as prime cost<\u002Fdiv>\n                   <div style=\"display:grid;grid-template-columns:54px 1fr 48px;gap:11px;align-items:center;margin-top:11px;\">\n                     <span style=\"font-size:12.5px;color:#3c4a5a;\">Labour<\u002Fspan>\n                     <div style=\"position:relative;height:9px;background:#f1ece1;border-radius:5px;\">\n                       <div style=\"position:absolute;left:0;top:0;bottom:0;width:79%;background:#bf8a2e;border-radius:5px;\"><\u002Fdiv>\n                       <div style=\"position:absolute;left:77%;top:-2px;bottom:-2px;width:1.5px;background:#15293f;\"><\u002Fdiv>\n                     <\u002Fdiv>\n                     <span class=\"cs\" style=\"font-size:13px;font-weight:700;color:#b6831f;text-align:right;\">27.8%<\u002Fspan>\n                   <\u002Fdiv>\n                   <div style=\"display:grid;grid-template-columns:54px 1fr 48px;gap:11px;align-items:center;margin-top:9px;\">\n                     <span style=\"font-size:12.5px;color:#3c4a5a;\">Food<\u002Fspan>\n                     <div style=\"position:relative;height:9px;background:#f1ece1;border-radius:5px;\">\n                       <div style=\"position:absolute;left:0;top:0;bottom:0;width:92%;background:#bf8a2e;border-radius:5px;\"><\u002Fdiv>\n                       <div style=\"position:absolute;left:86%;top:-2px;bottom:-2px;width:1.5px;background:#15293f;\"><\u002Fdiv>\n                     <\u002Fdiv>\n                     <span class=\"cs\" style=\"font-size:13px;font-weight:700;color:#b6831f;text-align:right;\">32.1%<\u002Fspan>\n                   <\u002Fdiv>\n                   <div style=\"font-size:11px;color:#a3a9b1;margin-top:8px;\">Bars are this week, the mark is target. Both run a little over.<\u002Fdiv>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <sc-if value=\"{{l.open}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:11px;background:#faf8f3;border:1px solid #eee9dd;border-radius:8px;padding:11px 13px;\">\n                   <div style=\"font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:#a3956f;margin-bottom:5px;\">{{l.statusLabel}}<\u002Fdiv>\n                   <sc-for list=\"{{l.source}}\" as=\"ln\" hint-placeholder-count=\"2\">\n                     <div style=\"font-size:13.5px;color:#5a6675;line-height:1.5;margin-top:3px;\">{{ln.t}}<\u002Fdiv>\n                   <\u002Fsc-for>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- cost of inaction (terracotta) -->\n               <sc-if value=\"{{l.hasInaction}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:14px;border-left:3px solid #b23a2e;background:#fdf3f2;padding:10px 14px;border-radius:0 8px 8px 0;\">\n                   <div style=\"font-size:10.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#b23a2e;\">If you do nothing<\u002Fdiv>\n                   <div style=\"font-size:13.5px;color:#3c4a5a;margin-top:4px;line-height:1.5;\">{{l.inaction}}<\u002Fdiv>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- the saving side (green) -->\n               <sc-if value=\"{{l.hasSaving}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:10px;border-left:3px solid #2f6b4f;background:#f3f8f5;padding:10px 14px;border-radius:0 8px 8px 0;\">\n                   <div style=\"font-size:10.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#2f6b4f;\">The saving<\u002Fdiv>\n                   <div style=\"font-size:13.5px;color:#3c4a5a;margin-top:4px;line-height:1.5;\">{{l.saving}}<\u002Fdiv>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- reorder: seldom ordered catch + reconciliation preview -->\n               <sc-if value=\"{{l.hasSeldom}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:11px;display:flex;align-items:flex-start;gap:9px;background:#faf8f3;border:1px solid #eee9dd;border-radius:8px;padding:10px 13px;\">\n                   <span aria-hidden=\"true\" style=\"flex:none;margin-top:1px;color:#bf8a2e;\">{{historyIcon}}<\u002Fspan>\n                   <div style=\"font-size:13px;color:#3c4a5a;line-height:1.5;\">{{l.seldom}}<\u002Fdiv>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n               <sc-if value=\"{{l.hasRecon}}\" hint-placeholder-val=\"{{false}}\">\n               <\u002Fsc-if>\n\n               <!-- staffing action, gated by scheduling permission -->\n               <sc-if value=\"{{l.isStaff}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:14px;\">\n                   <sc-if value=\"{{l.permEdit}}\" hint-placeholder-val=\"{{true}}\">\n                     <sc-if value=\"{{l.staffIdle}}\" hint-placeholder-val=\"{{true}}\">\n                       <button type=\"button\" onclick=\"{{proposeStaff}}\" style=\"border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 16px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Propose the roster fix<\u002Fbutton>\n                     <\u002Fsc-if>\n                     <sc-if value=\"{{l.staffProposed}}\" hint-placeholder-val=\"{{false}}\">\n                       <div style=\"background:#f4f8f5;border:1px solid #d6e6dc;border-radius:9px;padding:13px 15px;\">\n                         <div style=\"font-size:13.5px;color:#2c4a39;line-height:1.5;\">Add one Friday, two Saturday, drop one Sunday. Labour holds near 27% of sales.<\u002Fdiv>\n                         <div style=\"display:flex;gap:10px;margin-top:11px;flex-wrap:wrap;\">\n                           <button type=\"button\" onclick=\"{{confirmStaff}}\" style=\"border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13px;font-weight:600;padding:9px 15px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Confirm<\u002Fbutton>\n                           <button type=\"button\" onclick=\"{{cancelStaff}}\" style=\"border:1px solid #cdbf9f;background:#fff;border-radius:8px;color:#6f7d8c;font-size:13px;font-weight:600;padding:9px 15px;cursor:pointer;font-family:inherit;\">Cancel<\u002Fbutton>\n                         <\u002Fdiv>\n                       <\u002Fdiv>\n                     <\u002Fsc-if>\n                     <sc-if value=\"{{l.staffApplied}}\" hint-placeholder-val=\"{{false}}\">\n                       <span style=\"display:inline-flex;align-items:center;gap:8px;font-size:13.5px;font-weight:600;color:#2f6b4f;\">{{checkIcon}} Roster updated <button type=\"button\" onclick=\"{{cancelStaff}}\" style=\"margin-left:4px;font-size:12.5px;color:#6f7d8c;background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:underline;\">Undo<\u002Fbutton><\u002Fspan>\n                     <\u002Fsc-if>\n                   <\u002Fsc-if>\n                   <sc-if value=\"{{l.permCentral}}\" hint-placeholder-val=\"{{false}}\">\n                     <sc-if value=\"{{l.notifyIdle}}\" hint-placeholder-val=\"{{true}}\">\n                       <button type=\"button\" onclick=\"{{notifyScheduler}}\" style=\"border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 16px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Notify the scheduler<\u002Fbutton>\n                       <div style=\"font-size:11.5px;color:#a3a9b1;margin-top:7px;\">Scheduling is centralised, so the store flags it and head office makes the change.<\u002Fdiv>\n                     <\u002Fsc-if>\n                     <sc-if value=\"{{l.notifySent}}\" hint-placeholder-val=\"{{false}}\">\n                       <span style=\"display:inline-flex;align-items:center;gap:8px;font-size:13.5px;font-weight:600;color:#2f6b4f;\">{{checkIcon}} Scheduler notified <button type=\"button\" onclick=\"{{undoNotify}}\" style=\"margin-left:4px;font-size:12.5px;color:#6f7d8c;background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:underline;\">Undo<\u002Fbutton><\u002Fspan>\n                     <\u002Fsc-if>\n                   <\u002Fsc-if>\n                   <div style=\"display:inline-flex;align-items:center;gap:6px;margin-left:0;margin-top:11px;background:#f1ece1;border-radius:8px;padding:3px;\">\n                     <sc-for list=\"{{permTabs}}\" as=\"pt\" hint-placeholder-count=\"2\">\n                       <button type=\"button\" onclick=\"{{setSchedPerm}}\" data-perm=\"{{pt.key}}\" aria-pressed=\"{{pt.on}}\" style=\"border:none;cursor:pointer;font-family:inherit;font-size:11px;font-weight:600;padding:5px 10px;border-radius:6px;background:{{pt.bg}};color:{{pt.fg}};\">{{pt.label}}<\u002Fbutton>\n                     <\u002Fsc-for>\n                   <\u002Fdiv>\n                   <!-- rostering pathway entry, mirrors the stock count CTA -->\n                   <div style=\"margin-top:14px;background:#faf8f3;border:1px solid #eee9dd;border-radius:10px;padding:14px 16px;\">\n                     <div style=\"display:flex;align-items:center;gap:8px;\">\n                       <span style=\"font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:#5a6675;background:#fff;border:1px solid #ddd5c6;border-radius:4px;padding:3px 7px;\">AI scheduling · machine learning<\u002Fspan>\n                       <span style=\"font-size:9.5px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#bf8a2e;border:1px solid #ecdcb8;border-radius:4px;padding:2px 7px;\">Roadmap<\u002Fspan>\n                     <\u002Fdiv>\n                     <div style=\"font-size:13px;color:#3c4a5a;line-height:1.5;margin-top:9px;max-width:440px;\">The same ML demand forecast that builds your order builds your roster. See this week’s copied schedule, the conflicts it hides, and the forecast-driven fix. Nothing publishes without your confirmation.<\u002Fdiv>\n                     <button type=\"button\" onclick=\"{{openPath}}\" data-track=\"sched\" style=\"margin-top:12px;display:inline-flex;align-items:center;gap:8px;border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 18px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\"><span aria-hidden=\"true\" style=\"display:inline-flex;\">{{layersIconWhite}}<\u002Fspan> Build the schedule →<\u002Fbutton>\n                   <\u002Fdiv>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- gp action: upsell -->\n               <sc-if value=\"{{l.isUpsell}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:14px;\">\n                   <sc-if value=\"{{l.upsellIdle}}\" hint-placeholder-val=\"{{true}}\">\n                     <button type=\"button\" onclick=\"{{applyUpsell}}\" style=\"border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 16px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Push the side of chips, +$640 a week<\u002Fbutton>\n                   <\u002Fsc-if>\n                   <sc-if value=\"{{l.upsellApplied}}\" hint-placeholder-val=\"{{false}}\">\n                     <span style=\"display:inline-flex;align-items:center;gap:8px;font-size:13.5px;font-weight:600;color:#2f6b4f;\">{{checkIcon}} Briefed to the floor <button type=\"button\" onclick=\"{{undoUpsell}}\" style=\"margin-left:4px;font-size:12.5px;color:#6f7d8c;background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:underline;\">Undo<\u002Fbutton><\u002Fspan>\n                   <\u002Fsc-if>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- count action: leads to the guided ordering pathway -->\n               <sc-if value=\"{{l.isCount}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:14px;background:#faf8f3;border:1px solid #eee9dd;border-radius:10px;padding:14px 16px;\">\n                   <div style=\"display:flex;align-items:center;gap:8px;\">\n                     <span style=\"font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:#5a6675;background:#fff;border:1px solid #ddd5c6;border-radius:4px;padding:3px 7px;\">AI ordering · machine learning<\u002Fspan>\n                   <\u002Fdiv>\n                   <div style=\"font-size:13px;color:#3c4a5a;line-height:1.5;margin-top:9px;max-width:440px;\">Tonight’s order forecast updates when your count is submitted. Machine learning on sales and stock history, not a chatbot. Your confirmation is always required before any order is placed.<\u002Fdiv>\n                   <button type=\"button\" onclick=\"{{openPath}}\" data-track=\"order\" style=\"margin-top:12px;display:inline-flex;align-items:center;gap:8px;border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 18px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\"><span aria-hidden=\"true\" style=\"display:inline-flex;\">{{micIconWhite}}<\u002Fspan> Start stock count →<\u002Fbutton>\n                 <\u002Fdiv>\n               <\u002Fsc-if>\n\n               <!-- reorder action -->\n               <sc-if value=\"{{l.isReorder}}\" hint-placeholder-val=\"{{false}}\">\n                 <div style=\"margin-top:14px;\">\n                   <sc-if value=\"{{l.reorderIdle}}\" hint-placeholder-val=\"{{true}}\">\n                     <button type=\"button\" onclick=\"{{applyReorder}}\" style=\"border:none;border-radius:8px;background:#15293f;color:#fff;font-size:13.5px;font-weight:600;padding:11px 16px;cursor:pointer;font-family:inherit;\" style-hover=\"background:#22364d;\">Add the reorder, $527<\u002Fbutton>\n                   <\u002Fsc-if>\n                   <sc-if value=\"{{l.reorderApplied}}\" hint-placeholder-val=\"{{false}}\">\n                     <span style=\"display:inline-flex;align-items:center;gap:8px;font-size:13.5px;font-weight:600;color:#2f6b4f;\">{{checkIcon}} Order drafted for Wednesday <button type=\"button\" onclick=\"{{undoReorder}}\" style=\"margin-left:4px;font-size:12.5px;color:#6f7d8c;background:none;border:none;cursor:pointer;font-family:inherit;text-decoration:underline;\">Undo<\u002Fbutton><\u002Fspan>\n                   <\u002Fsc-if>\n                 <\u002Fdiv>\n                 <!-- order management: what is already in flight -->\n                 <sc-if value=\"{{l.hasOrders}}\" hint-placeholder-val=\"{{false}}\">\n                   <div style=\"margin-top:13px;border:1px solid #eee9dd;border-radius:9px;padding:11px 13px;\">\n                     <div style=\"font-size:10.5px;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:#a3956f;margin-bottom:7px;\">Already on the way<\u002Fdiv>\n                     <sc-for list=\"{{l.orders}}\" as=\"o\" hint-placeholder-count=\"2\">\n                       <div style=\"display:flex;align-items:flex-start;gap:9px;padding:4px 0;\">\n                         <span aria-hidden=\"true\" style=\"flex:none;width:8px;height:8px;border-radius:50%;background:{{o.dot}};margin-top:5px;\"><\u002Fspan>\n                         <div style=\"min-width:0;\">\n                           <span style=\"font-size:13px;color:#15293f;\">{{o.label}}<\u002Fspan>\n                           <span style=\"font-size:12.5px;color:#8a94a0;\"> · {{o.status}}<\u002Fspan>\n                         <\u002Fdiv>\n                       <\u002Fdiv>\n                     <\u002Fsc-for>\n                   <\u002Fdiv>\n                 <\u002Fsc-if>\n               <\u002Fsc-if>\n             <\u002Fdiv>\n                 <\u002Fsc-for>\n                 <!-- explore further, scoped to this category, opens the panel with context set -->\n              